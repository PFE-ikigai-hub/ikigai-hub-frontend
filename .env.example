# Backend API base URL used by the frontend in production/staging.
# Example: https://ikigai-hub-backend.onrender.com
VITE_API_URL=

# Optional: local Vite proxy target (used only by `npm run dev`).
# If omitted, defaults to http://127.0.0.1:3000 from vite.config.ts
VITE_PROXY_TARGET=http://127.0.0.1:3000
